    "prisma:studio": "npx prisma studio",
    "db:seed": "npx prisma db execute --file ../db/seeds/001_seed_dev.sql",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [],
